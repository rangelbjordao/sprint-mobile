# ============================
# SPOTIFY CONFIGURAÇÃO
# ============================
# Esse é necessário para que o app consiga autenticar via Spotify.

# Como obter o Client ID:
# Como obter o Client ID e configurar a Redirect URI:
# 1️⃣ Acesse: https://developer.spotify.com/dashboard/
# 2️⃣ Faça login com sua conta Spotify.
# 3️⃣ Clique em "Create an App" (Criar um App), preencha nome e descrição.
# 4️⃣ Adicione uma Redirect URI temporária (pode ser exp://127.0.0.1).
# 5️⃣ Após criar o App, copie o "Client ID" do painel do App.
# 6️⃣ Cole o Client ID abaixo.
# 7️⃣ Depois rode o app no Expo para descobrir a Redirect URI correta via log e atualize no Spotify.


EXPO_PUBLIC_SPOTIFY_CLIENT_ID=SEU_CLIENT_ID_AQUI

# ============================
# REDIRECT URI
# ============================

# Para o login funcionar, você precisa registrar uma Redirect URI no Spotify:
# 1️⃣ Rode o app no Expo Go (Android/iOS) ou em emulador.
# 2️⃣ Abra o console (terminal ou log do Expo).
# 3️⃣ Procure o log:
#    "🔹 Redirect URI: exp://<SEU_IP>:<PORTA>"
#    Exemplo: exp://192.168.00.00:8081
# 4️⃣ Copie exatamente essa URI e adicione no painel do seu App Spotify em:
#    Settings > Redirect URIs > Add
# 5️⃣ Salve as alterações no Spotify.

# ============================
# NOTAS PARA RODAR O APP
# ============================

# 1️⃣ Clone o repositório.
# 2️⃣ Copie este arquivo para .env
# 3️⃣ Substitua SEU_CLIENT_ID_AQUI pelo Client ID obtido no Spotify.
